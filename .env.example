# ──────────────────────────────────────────────────────────────────────
# llm-contract-harness — Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then load before running the web server:
#   set -a && source .env && set +a
# ──────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────

# OpenAI API key (used by both planner and factory LLM calls)
OPENAI_API_KEY="sk-..."

# ── Web Server ────────────────────────────────────────────────────────

# Bind address and port for the FastAPI server.
# PORT is checked first (App Runner / Heroku convention), then LLMCH_PORT.
# LLMCH_HOST="127.0.0.1"
# LLMCH_PORT="8000"
# PORT="8000"

# ── Artifacts ─────────────────────────────────────────────────────────

# Root directory for all run artifacts (planner, factory, pipeline).
# Defaults to ./artifacts.  CLI tools also honour ARTIFACTS_DIR (no prefix).
# LLMCH_ARTIFACTS_DIR="./artifacts"

# ── Demo Push ─────────────────────────────────────────────────────────

# Git remote URL for the "push to demo repo" feature.
# Leave empty to disable.  Supports SSH and HTTPS URLs.
# For local dev (SSH):
# LLMCH_DEMO_REMOTE_URL="git@github.com:youruser/yourrepo.git"
# For AWS / containers (HTTPS + token):
# LLMCH_DEMO_REMOTE_URL="https://github.com/youruser/yourrepo.git"
# LLMCH_DEMO_REMOTE_TOKEN="ghp_..."   # GitHub PAT — auto-embeds into the HTTPS URL

# ── Rate Limiting ─────────────────────────────────────────────────────

# Per-IP daily run limit (default: 3 for public demos)
LLMCH_RATE_LIMIT_PER_IP="3"

# Global daily run limit across all IPs (default: 100)
LLMCH_RATE_LIMIT_GLOBAL="100"

# ── DynamoDB (optional) ───────────────────────────────────────────────

# DynamoDB table name for run metadata.  Leave empty to use local JSON files.
# When set, RunStore uses DynamoDB instead of artifacts/pipeline/{id}/meta.json.
# Requires boto3 and IAM permissions (dynamodb:PutItem, GetItem, UpdateItem).
# LLMCH_DYNAMO_TABLE="llmch-runs"

# ── S3 Artifact Storage (optional) ────────────────────────────────────

# S3 bucket for durable artifact storage.  Leave empty to skip upload.
# When set, all run artifacts are uploaded to s3://{bucket}/runs/{run_id}/
# after each pipeline run completes.  Requires boto3 and IAM permissions.
# LLMCH_S3_BUCKET="my-llmch-artifacts"

# ── Factory Runtime ───────────────────────────────────────────────────

# Skip per-repo venv creation (set to 1 in Docker where pytest is pre-installed)
# LLMCH_SKIP_REPO_VENV="1"

# ── Display (CLI only) ───────────────────────────────────────────────

# Disable colored terminal output (standard: https://no-color.org/)
# NO_COLOR="1"

# Force colored output even when not a TTY
# FORCE_COLOR="1"
